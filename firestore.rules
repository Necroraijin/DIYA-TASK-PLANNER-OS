rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net: Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Standalone Global Helper Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid is string 
        && data.username is string 
        && data.username.size() <= 100
        && data.email is string
        && data.email.size() <= 150
        && (data.encryptionKey == null || data.encryptionKey is string);
    }
    
    function isValidTask(data) {
      return data.id is string
        && data.userId is string
        && data.userId == request.auth.uid
        && data.title is string
        && data.title.size() <= 200
        && data.category is string
        && data.priority is string
        && data.status is string;
    }
    
    function isValidHabit(data) {
      return data.id is string
        && data.userId is string
        && data.userId == request.auth.uid
        && data.title is string
        && data.title.size() <= 200
        && data.category is string
        && data.completedDays is list
        && data.streak is int;
    }
    
    function isValidNotification(data) {
      return data.id is string
        && data.userId is string
        && data.userId == request.auth.uid
        && data.title is string
        && data.title.size() <= 200
        && data.description is string
        && data.read is bool;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Users cannot be deleted from client SDK
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(request.resource.data);
      allow update: if isSignedIn() && isValidId(taskId) && isValidTask(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Habits Collection ---
    match /habits/{habitId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(habitId) && isValidHabit(request.resource.data);
      allow update: if isSignedIn() && isValidId(habitId) && isValidHabit(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Notifications Collection ---
    match /notifications/{notifId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notifId) && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && isValidId(notifId) && isValidNotification(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
